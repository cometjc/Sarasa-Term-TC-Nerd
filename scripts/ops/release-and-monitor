#!/usr/bin/env bash
set -euo pipefail

tag=""
workflow="Release"
remote="origin"
push_main=1
min_bytes="${MIN_RELEASE_ASSET_BYTES:-10485760}"

usage() {
  cat <<'EOF'
Usage: scripts/ops/release-and-monitor [--tag vYYYY.MM.DD.N] [--no-push-main]

Pushes main, pushes a v* release tag, waits for the Release workflow, and checks
published release asset sizes.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --tag)
      tag="$2"
      shift 2
      ;;
    --workflow)
      workflow="$2"
      shift 2
      ;;
    --no-push-main)
      push_main=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

require_command() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "Missing required command: $1" >&2
    exit 1
  }
}

require_command git
require_command gh
require_command jq

if [[ -n "$(git status --porcelain)" ]]; then
  echo "Working tree is dirty; commit or stash changes before releasing." >&2
  exit 1
fi

if [[ -z "$tag" ]]; then
  base="v$(date +%Y.%m.%d)"
  for n in $(seq 0 99); do
    candidate="$base"
    if (( n > 0 )); then
      candidate="$base.$n"
    fi
    if ! git rev-parse -q --verify "refs/tags/$candidate" >/dev/null &&
       ! git ls-remote --exit-code --tags "$remote" "refs/tags/$candidate" >/dev/null 2>&1; then
      tag="$candidate"
      break
    fi
  done
fi

if [[ -z "$tag" || "$tag" != v* ]]; then
  echo "Release tag must start with v*: $tag" >&2
  exit 1
fi

if (( push_main )); then
  git push "$remote" main
fi

head_sha="$(git rev-parse HEAD)"
if git rev-parse -q --verify "refs/tags/$tag" >/dev/null; then
  tag_sha="$(git rev-list -n 1 "$tag")"
  if [[ "$tag_sha" != "$head_sha" ]]; then
    echo "Local tag $tag points at $tag_sha, not HEAD $head_sha" >&2
    exit 1
  fi
else
  git tag "$tag"
fi

git push "$remote" "$tag"

echo "Waiting for $workflow workflow run for $tag"
run_id=""
for _ in $(seq 1 24); do
  run_id="$(gh run list --workflow "$workflow" --branch "$tag" --limit 1 --json databaseId --jq '.[0].databaseId // ""')"
  if [[ -n "$run_id" ]]; then
    break
  fi
  sleep 5
done

if [[ -z "$run_id" ]]; then
  echo "No workflow run found for tag $tag" >&2
  exit 1
fi

run_url="$(gh run view "$run_id" --json url --jq '.url')"
echo "Run: $run_url"

while true; do
  status_json="$(gh run view "$run_id" --json status,conclusion)"
  status="$(jq -r '.status' <<<"$status_json")"
  conclusion="$(jq -r '.conclusion // ""' <<<"$status_json")"
  echo "Run status: $status ${conclusion}"
  if [[ "$status" == "completed" ]]; then
    break
  fi
  sleep 30
done

if [[ "$conclusion" != "success" ]]; then
  echo "Release workflow failed with conclusion: $conclusion" >&2
  exit 1
fi

release_json="$(gh release view "$tag" --json url,assets,name,publishedAt)"
release_url="$(jq -r '.url' <<<"$release_json")"
echo "Release: $release_url"

asset_lines="$(jq -r '.assets[] | select(.name | test("^SarasaTermTCNerd.*\\.(tar\\.gz|7z|ttf)$")) | [.size, .name] | @tsv' <<<"$release_json")"
if [[ -z "$asset_lines" ]]; then
  echo "No SarasaTermTCNerd release assets found for $tag" >&2
  exit 1
fi

while IFS=$'\t' read -r size name; do
  if (( size < min_bytes )); then
    echo "$name is unexpectedly small: $size bytes" >&2
    exit 1
  fi
  printf '%s\t%s\n' "$size" "$name"
done <<<"$asset_lines"
